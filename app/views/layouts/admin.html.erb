<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "OneTicketAway Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application" %>
  </head>

  <body class="site-shell">
    <header class="site-header">
      <div class="shell">
        <div class="site-branding">
          <a href="<%= admin_root_path %>" class="site-branding__name">OneTicketAway Admin</a>
          <p class="site-branding__tag">Blog yazilarini yonet</p>
        </div>

        <nav class="site-nav">
          <%= link_to "Ana Sayfa", "/" %>
          <% if admin_logged_in? %>
            <%= link_to "Yeni Yazi", new_admin_post_path %>
            <%= button_to "Cikis", admin_logout_path, method: :delete, form_class: "inline-form" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="shell page-content">
      <% flash.each do |type, message| %>
        <div class="flash flash--<%= type %>"><%= message %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
