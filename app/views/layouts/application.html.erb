<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "OneTicketAway" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:meta_description) || "Travel stories, blog posts and editorial content from OneTicketAway." %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application" %>
  </head>

  <body class="site-shell">
    <header class="site-header">
      <div class="shell">
        <div class="site-branding">
          <a href="/" class="site-branding__name">OneTicketAway</a>
          <p class="site-branding__tag">Travel blog and publishing dashboard</p>
        </div>

        <nav class="site-nav">
          <%= link_to "Home", "/" %>
          <%= link_to "Latest Posts", "/" %>
          <%= link_to(admin_logged_in? ? "Admin" : "Admin Login", admin_root_path) %>
        </nav>
      </div>
    </header>

    <main class="shell page-content">
      <% flash.each do |type, message| %>
        <div class="flash flash--<%= type %>"><%= message %></div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="site-footer">
      <div class="shell">
        <p>&copy; <%= Time.current.year %> OneTicketAway</p>
      </div>
    </footer>
  </body>
</html>
