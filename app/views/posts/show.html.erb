<% content_for :title, "#{@post.seo_title} | OneTicketAway" %>
<% content_for :meta_description, @post.seo_description %>

<article class="article-content">
  <p class="eyebrow">Blog Post</p>
  <h1><%= @post.title %></h1>
  <p class="article-meta">
    <%= l(@post.published_at || @post.created_at, format: :long) %>
  </p>

  <% if @post.cover_image_url.present? %>
    <p>
      <img src="<%= @post.cover_image_url %>" alt="<%= @post.title %> kapak gorseli">
    </p>
  <% end %>

  <% if @post.excerpt.present? %>
    <p><strong><%= @post.excerpt %></strong></p>
  <% end %>

  <div class="prose">
    <%= simple_format(@post.body) %>
  </div>

  <div class="actions">
    <%= link_to "Tum yazilar", posts_path, class: "button button--secondary" %>
  </div>
</article>
