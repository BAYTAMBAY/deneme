<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "OneTicketAway Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application" %>
  </head>

  <body class="site-shell admin-theme">
    <div class="admin-background"></div>

    <header class="site-header admin-header">
      <div class="shell admin-header__inner">
        <div class="site-branding">
          <p class="site-branding__eyebrow">OneTicketAway</p>
          <a href="<%= admin_root_path %>" class="site-branding__name">Editorial Desk</a>
          <p class="site-branding__tag">Blog yazilarini yonet, duzenle ve yayina hazirla.</p>
        </div>

        <nav class="site-nav admin-nav">
          <%= link_to "Panel", admin_root_path, class: "nav-pill" %>
          <%= link_to "Ana Sayfa", "/", class: "nav-pill nav-pill--soft" %>
          <% if admin_logged_in? %>
            <%= link_to "Yeni Yazi", new_admin_post_path, class: "nav-pill nav-pill--primary" %>
            <%= button_to "Cikis", admin_logout_path, method: :delete, form_class: "inline-form", class: "nav-pill nav-pill--ghost" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="shell page-content admin-page-content">
      <% flash.each do |type, message| %>
        <div class="flash flash--<%= type %>"><%= message %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
