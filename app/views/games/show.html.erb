<% content_for :title, "Games | OneTicketAway" %>
<% content_for :meta_description, "OneTicketAway mini arcade. Birden fazla kucuk tarayici oyunu ile hiz, hafiza ve zamanlama becerini test et." %>

<section class="game-hero game-hero--arcade">
  <div class="game-hero__copy">
    <p class="eyebrow">Mini Arcade</p>
    <h1>Play Room</h1>
    <p>Burada tek oyun yerine kucuk bir arcade var. Farkli modlar arasinda gec, en yuksek skoru kovala ve keyifli bir mola ver.</p>

    <div class="game-selector" role="tablist" aria-label="Oyun sec">
      <button type="button" class="game-selector__button is-active" data-game-tab="sky-chase">Sky Chase</button>
      <button type="button" class="game-selector__button" data-game-tab="memory-route">Memory Route</button>
      <button type="button" class="game-selector__button" data-game-tab="perfect-landing">Perfect Landing</button>
      <button type="button" class="game-selector__button" data-game-tab="travel-dash">Travel Dash</button>
      <button type="button" class="game-selector__button" data-game-tab="turbo-race">3D Car Race</button>
    </div>

    <div class="actions">
      <%= link_to "Ana sayfaya don", root_path, class: "button button--secondary" %>
    </div>
  </div>

  <div class="game-hero__panel game-hero__panel--stack">
    <section class="game-pane is-active" id="game-sky-chase" data-game-pane="sky-chase">
      <div class="game-pane__header">
        <div>
          <p class="eyebrow">Speed</p>
          <h2>Sky Chase</h2>
          <p>30 saniye boyunca beliren hedefleri yakala. Kucuk hedef daha fazla puan getirir.</p>
        </div>
        <div class="game-stats">
          <div class="game-stat">
            <span>Skor</span>
            <strong id="sky-score">0</strong>
          </div>
          <div class="game-stat">
            <span>Sure</span>
            <strong id="sky-timer">30</strong>
          </div>
          <div class="game-stat">
            <span>En iyi</span>
            <strong id="sky-best-score">0</strong>
          </div>
        </div>
      </div>

      <div class="actions">
        <button type="button" id="start-sky-game">Oyunu Baslat</button>
      </div>

      <div class="game-board" id="sky-game-board" aria-live="polite">
        <div class="game-board__overlay" id="sky-game-overlay">
          <strong>Hazir misin?</strong>
          <span>Baslat'a tikla ve hedefleri yakala.</span>
        </div>
        <button type="button" class="target target--hidden" id="sky-target" aria-label="Target"></button>
      </div>
    </section>

    <section class="game-pane" id="game-memory-route" data-game-pane="memory-route">
      <div class="game-pane__header">
        <div>
          <p class="eyebrow">Memory</p>
          <h2>Memory Route</h2>
          <p>Işık sırasını aklında tut, sonra karelere ayni sirayla bas. Her turda dizi bir adim uzar.</p>
        </div>
        <div class="game-stats">
          <div class="game-stat">
            <span>Seviye</span>
            <strong id="memory-level">0</strong>
          </div>
          <div class="game-stat">
            <span>Hamle</span>
            <strong id="memory-step">0</strong>
          </div>
          <div class="game-stat">
            <span>En iyi</span>
            <strong id="memory-best">0</strong>
          </div>
        </div>
      </div>

      <div class="actions">
        <button type="button" id="start-memory-game">Diziyi Baslat</button>
      </div>

      <div class="memory-board" id="memory-board">
        <button type="button" class="memory-tile memory-tile--1" data-memory-tile="0" aria-label="Birinci kare"></button>
        <button type="button" class="memory-tile memory-tile--2" data-memory-tile="1" aria-label="Ikinci kare"></button>
        <button type="button" class="memory-tile memory-tile--3" data-memory-tile="2" aria-label="Ucuncu kare"></button>
        <button type="button" class="memory-tile memory-tile--4" data-memory-tile="3" aria-label="Dorduncu kare"></button>
      </div>
      <p class="game-note" id="memory-note">Baslat'a tikla, sirayi izle ve tekrar et.</p>
    </section>

    <section class="game-pane" id="game-perfect-landing" data-game-pane="perfect-landing">
      <div class="game-pane__header">
        <div>
          <p class="eyebrow">Timing</p>
          <h2>Perfect Landing</h2>
          <p>Gosterge hareket ederken butona bas ve ucagi hedef bolgede indir. Uca yaklastikca daha cok puan alirsin.</p>
        </div>
        <div class="game-stats">
          <div class="game-stat">
            <span>Skor</span>
            <strong id="landing-score">0</strong>
          </div>
          <div class="game-stat">
            <span>Tur</span>
            <strong id="landing-round">0</strong>
          </div>
          <div class="game-stat">
            <span>En iyi</span>
            <strong id="landing-best">0</strong>
          </div>
        </div>
      </div>

      <div class="actions">
        <button type="button" id="start-landing-game">Pisti Ac</button>
        <button type="button" id="stop-landing-game" class="button button--secondary" disabled>Indir</button>
      </div>

      <div class="landing-board">
        <div class="landing-track">
          <div class="landing-track__target"></div>
          <div class="landing-track__marker" id="landing-marker"></div>
        </div>
      </div>
      <p class="game-note" id="landing-note">Baslat'a tikla, cizgi akmaya baslasin. Hedef bolgeye gelince indir.</p>
    </section>

    <section class="game-pane" id="game-travel-dash" data-game-pane="travel-dash">
      <div class="game-pane__header">
        <div>
          <p class="eyebrow">Runner</p>
          <h2>Travel Dash</h2>
          <p>Perspektifli pistte kos, valiz ve biletleri topla, engellerden kac. Klavyede sag-sol ya da ekrandaki butonlari kullan.</p>
        </div>
        <div class="game-stats">
          <div class="game-stat">
            <span>Skor</span>
            <strong id="dash-score">0</strong>
          </div>
          <div class="game-stat">
            <span>Sure</span>
            <strong id="dash-timer">45</strong>
          </div>
          <div class="game-stat">
            <span>En iyi</span>
            <strong id="dash-best">0</strong>
          </div>
        </div>
      </div>

      <div class="actions">
        <button type="button" id="start-dash-game">Travel Dash Baslat</button>
        <button type="button" id="dash-left" class="button button--secondary">Sola</button>
        <button type="button" id="dash-right" class="button button--secondary">Saga</button>
      </div>

      <div class="travel-dash-board" id="travel-dash-board">
        <div class="travel-dash-hud" id="dash-hud">Pist hazir. Baslat ve kosturmaya basla.</div>
        <div class="travel-dash-sky"></div>
        <div class="travel-dash-road">
          <div class="travel-dash-lane"></div>
          <div class="travel-dash-lane"></div>
          <div class="travel-dash-lane"></div>
          <div class="travel-dash-lane"></div>
          <div class="travel-dash-items" id="dash-items"></div>
          <div class="travel-dash-player lane-center" id="dash-player">
            <div class="travel-dash-player__body"></div>
            <div class="travel-dash-player__shadow"></div>
          </div>
        </div>
      </div>
      <p class="game-note">Masaustu: sol ve sag ok tuslari. Mobil: ekrandaki butonlar.</p>
    </section>

    <section class="game-pane" id="game-turbo-race" data-game-pane="turbo-race">
      <div class="game-pane__header">
        <div>
          <p class="eyebrow">3D Race</p>
          <h2>Turbo Boulevard</h2>
          <p>Perspektifli pistte ilerle, rakiplerden kac ve hizi koru. Sol-sag ile serit degistir, yukari ile hizlan.</p>
        </div>
        <div class="game-stats">
          <div class="game-stat">
            <span>Skor</span>
            <strong id="race-score">0</strong>
          </div>
          <div class="game-stat">
            <span>Hiz</span>
            <strong id="race-speed">0</strong>
          </div>
          <div class="game-stat">
            <span>En iyi</span>
            <strong id="race-best">0</strong>
          </div>
        </div>
      </div>

      <div class="actions">
        <button type="button" id="start-race-game">Yarisi Baslat</button>
        <button type="button" id="race-left" class="button button--secondary">Sola</button>
        <button type="button" id="race-right" class="button button--secondary">Saga</button>
      </div>

      <div class="race-canvas-shell">
        <canvas id="race-canvas" width="960" height="540" aria-label="3D car race"></canvas>
      </div>
      <p class="game-note" id="race-note">Masaustu: sol-sag ile yon ver, yukari ile hizlan. Mobilde butonlari kullan.</p>
    </section>
  </div>
</section>

<section class="panel panel--spacious game-instructions">
  <p class="eyebrow">Arcade Listesi</p>
  <h2 class="page-title">Birden fazla oyun, tek sayfa</h2>
  <div class="article-grid">
    <article class="article-card">
      <div class="article-card__body">
        <h3>Sky Chase</h3>
        <p>Refleks oyunu. Hedefleri hizli yakala, kacirmadan sureyi iyi kullan.</p>
      </div>
    </article>
    <article class="article-card">
      <div class="article-card__body">
        <h3>Memory Route</h3>
        <p>Hafiza oyunu. Yanan kareleri dogru sirayla tekrar ederek seviyeleri gec.</p>
      </div>
    </article>
    <article class="article-card">
      <div class="article-card__body">
        <h3>Perfect Landing</h3>
        <p>Zamanlama oyunu. Hareketli gostergede hedef bolgeyi tutturup yumusak inis yap.</p>
      </div>
    </article>
    <article class="article-card">
      <div class="article-card__body">
        <h3>Travel Dash</h3>
        <p>Sahte 3D runner. Yol perspektifinde ilerlerken seyahat biletlerini topla ve engellere carpmadan ak.</p>
      </div>
    </article>
    <article class="article-card">
      <div class="article-card__body">
        <h3>Turbo Boulevard</h3>
        <p>Canvas tabanli gosteri oyunu. Virajli yolda rakip arabalar arasindan akarak puan topla.</p>
      </div>
    </article>
  </div>
</section>

<script>
  (() => {
    const tabs = Array.from(document.querySelectorAll("[data-game-tab]"));
    const panes = Array.from(document.querySelectorAll("[data-game-pane]"));

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const selected = tab.dataset.gameTab;
        tabs.forEach((item) => item.classList.toggle("is-active", item === tab));
        panes.forEach((pane) => pane.classList.toggle("is-active", pane.dataset.gamePane === selected));
      });
    });

    const initSkyChase = () => {
      const board = document.getElementById("sky-game-board");
      const target = document.getElementById("sky-target");
      const overlay = document.getElementById("sky-game-overlay");
      const scoreEl = document.getElementById("sky-score");
      const timerEl = document.getElementById("sky-timer");
      const bestEl = document.getElementById("sky-best-score");
      const startButton = document.getElementById("start-sky-game");
      if (!board || !target || !overlay || !scoreEl || !timerEl || !bestEl || !startButton) return;

      const BEST_KEY = "oneticketaway-sky-chase-best";
      let score = 0;
      let timeLeft = 30;
      let gameTimer = null;
      let playing = false;

      const syncBestScore = () => {
        const bestScore = Number(window.localStorage.getItem(BEST_KEY) || 0);
        bestEl.textContent = String(bestScore);
        return bestScore;
      };

      const randomBetween = (min, max) => Math.floor(Math.random() * (max - min + 1)) + min;

      const moveTarget = () => {
        const boardRect = board.getBoundingClientRect();
        const size = randomBetween(44, 86);
        const maxLeft = Math.max(boardRect.width - size - 20, 20);
        const maxTop = Math.max(boardRect.height - size - 20, 20);

        target.style.width = `${size}px`;
        target.style.height = `${size}px`;
        target.style.left = `${randomBetween(12, maxLeft)}px`;
        target.style.top = `${randomBetween(12, maxTop)}px`;
        target.dataset.points = String(Math.max(6, Math.round(100 / size * 7)));
        target.classList.remove("target--hidden");
      };

      const finishGame = () => {
        playing = false;
        clearInterval(gameTimer);
        gameTimer = null;
        target.classList.add("target--hidden");

        const best = syncBestScore();
        if (score > best) {
          window.localStorage.setItem(BEST_KEY, String(score));
          bestEl.textContent = String(score);
        }

        overlay.innerHTML = `<strong>Oyun bitti</strong><span>Skorun ${score}. Tekrar dene ve rekorunu gelistir.</span>`;
        overlay.classList.remove("game-board__overlay--hidden");
        startButton.textContent = "Tekrar Oyna";
      };

      const startGame = () => {
        score = 0;
        timeLeft = 30;
        playing = true;
        scoreEl.textContent = "0";
        timerEl.textContent = "30";
        overlay.classList.add("game-board__overlay--hidden");
        startButton.textContent = "Oynaniyor...";
        moveTarget();

        clearInterval(gameTimer);
        gameTimer = window.setInterval(() => {
          timeLeft -= 1;
          timerEl.textContent = String(timeLeft);
          if (timeLeft <= 0) finishGame();
        }, 1000);
      };

      startButton.addEventListener("click", () => {
        if (playing) return;
        startGame();
      });

      target.addEventListener("click", () => {
        if (!playing) return;
        score += Number(target.dataset.points || 10);
        scoreEl.textContent = String(score);
        moveTarget();
      });

      board.addEventListener("click", (event) => {
        if (!playing || event.target === target) return;
        score = Math.max(0, score - 5);
        timeLeft = Math.max(0, timeLeft - 1);
        scoreEl.textContent = String(score);
        timerEl.textContent = String(timeLeft);
        if (timeLeft <= 0) finishGame();
      });

      syncBestScore();
    };

    const initMemoryRoute = () => {
      const tiles = Array.from(document.querySelectorAll("[data-memory-tile]"));
      const startButton = document.getElementById("start-memory-game");
      const levelEl = document.getElementById("memory-level");
      const stepEl = document.getElementById("memory-step");
      const bestEl = document.getElementById("memory-best");
      const noteEl = document.getElementById("memory-note");
      if (!tiles.length || !startButton || !levelEl || !stepEl || !bestEl || !noteEl) return;

      const BEST_KEY = "oneticketaway-memory-route-best";
      let sequence = [];
      let playerIndex = 0;
      let locked = true;

      const best = () => Number(window.localStorage.getItem(BEST_KEY) || 0);
      const syncBest = () => { bestEl.textContent = String(best()); };
      const randomIndex = () => Math.floor(Math.random() * tiles.length);

      const flashTile = (index) => {
        const tile = tiles[index];
        if (!tile) return;
        tile.classList.add("is-lit");
        window.setTimeout(() => tile.classList.remove("is-lit"), 380);
      };

      const playSequence = () => {
        locked = true;
        noteEl.textContent = "Sirayi izle...";
        sequence.forEach((tileIndex, idx) => {
          window.setTimeout(() => flashTile(tileIndex), 550 * (idx + 1));
        });
        window.setTimeout(() => {
          locked = false;
          playerIndex = 0;
          stepEl.textContent = "1";
          noteEl.textContent = "Simdi sen tekrar et.";
        }, 550 * (sequence.length + 1));
      };

      const nextRound = () => {
        sequence.push(randomIndex());
        levelEl.textContent = String(sequence.length);
        stepEl.textContent = "0";
        playSequence();
      };

      const fail = () => {
        const currentBest = best();
        if (sequence.length - 1 > currentBest) {
          window.localStorage.setItem(BEST_KEY, String(sequence.length - 1));
          syncBest();
        }
        noteEl.textContent = `Yanlis kare. Ulastigin seviye ${Math.max(sequence.length - 1, 0)}. Tekrar baslat.`;
        locked = true;
      };

      startButton.addEventListener("click", () => {
        sequence = [];
        playerIndex = 0;
        locked = true;
        noteEl.textContent = "Hazirlaniyor...";
        nextRound();
      });

      tiles.forEach((tile, index) => {
        tile.addEventListener("click", () => {
          if (locked) return;
          flashTile(index);

          if (sequence[playerIndex] !== index) {
            fail();
            return;
          }

          playerIndex += 1;
          stepEl.textContent = String(playerIndex + 1);

          if (playerIndex >= sequence.length) {
            noteEl.textContent = "Dogru! Yeni tur geliyor.";
            locked = true;
            window.setTimeout(nextRound, 700);
          }
        });
      });

      syncBest();
    };

    const initPerfectLanding = () => {
      const marker = document.getElementById("landing-marker");
      const startButton = document.getElementById("start-landing-game");
      const stopButton = document.getElementById("stop-landing-game");
      const scoreEl = document.getElementById("landing-score");
      const roundEl = document.getElementById("landing-round");
      const bestEl = document.getElementById("landing-best");
      const noteEl = document.getElementById("landing-note");
      if (!marker || !startButton || !stopButton || !scoreEl || !roundEl || !bestEl || !noteEl) return;

      const BEST_KEY = "oneticketaway-perfect-landing-best";
      let running = false;
      let frameId = null;
      let direction = 1;
      let pos = 0;
      let score = 0;
      let round = 0;

      const syncBest = () => {
        bestEl.textContent = String(Number(window.localStorage.getItem(BEST_KEY) || 0));
      };

      const animate = () => {
        pos += direction * 1.8;
        if (pos >= 92) direction = -1;
        if (pos <= 0) direction = 1;
        marker.style.left = `${pos}%`;
        frameId = window.requestAnimationFrame(animate);
      };

      const stopRound = () => {
        running = false;
        startButton.disabled = false;
        stopButton.disabled = true;
        window.cancelAnimationFrame(frameId);

        const distanceFromCenter = Math.abs(pos - 50);
        const points = Math.max(0, 100 - Math.round(distanceFromCenter * 3.2));
        score += points;
        round += 1;

        scoreEl.textContent = String(score);
        roundEl.textContent = String(round);
        noteEl.textContent = points >= 85 ? "Mukemmel inis!" : points >= 55 ? "Iyi bir inis." : "Sert inis, bir tur daha dene.";

        const best = Number(window.localStorage.getItem(BEST_KEY) || 0);
        if (score > best) {
          window.localStorage.setItem(BEST_KEY, String(score));
          bestEl.textContent = String(score);
        }
      };

      startButton.addEventListener("click", () => {
        if (running) return;
        running = true;
        startButton.disabled = true;
        stopButton.disabled = false;
        noteEl.textContent = "Gostergede hedef bolgeyi yakala.";
        frameId = window.requestAnimationFrame(animate);
      });

      stopButton.addEventListener("click", () => {
        if (!running) return;
        stopRound();
      });

      syncBest();
    };

    const initTravelDash = () => {
      const board = document.getElementById("travel-dash-board");
      const itemsLayer = document.getElementById("dash-items");
      const player = document.getElementById("dash-player");
      const hud = document.getElementById("dash-hud");
      const startButton = document.getElementById("start-dash-game");
      const leftButton = document.getElementById("dash-left");
      const rightButton = document.getElementById("dash-right");
      const scoreEl = document.getElementById("dash-score");
      const timerEl = document.getElementById("dash-timer");
      const bestEl = document.getElementById("dash-best");
      if (!board || !itemsLayer || !player || !hud || !startButton || !leftButton || !rightButton || !scoreEl || !timerEl || !bestEl) return;

      const BEST_KEY = "oneticketaway-travel-dash-best";
      const lanes = ["lane-left", "lane-center", "lane-right"];
      let laneIndex = 1;
      let score = 0;
      let timeLeft = 45;
      let playing = false;
      let dashTimer = null;
      let animationFrame = null;
      let lastSpawn = 0;
      let lastTick = 0;
      let speed = 0.013;
      const items = [];

      const syncBest = () => {
        bestEl.textContent = String(Number(window.localStorage.getItem(BEST_KEY) || 0));
      };

      const setLane = (nextLane) => {
        laneIndex = Math.max(0, Math.min(2, nextLane));
        player.classList.remove(...lanes);
        player.classList.add(lanes[laneIndex]);
      };

      const laneToX = (index) => [20, 50, 80][index];

      const spawnItem = () => {
        const lane = Math.floor(Math.random() * 3);
        const collectible = Math.random() > 0.35;
        const element = document.createElement("div");
        element.className = collectible ? "travel-dash-item travel-dash-item--ticket" : "travel-dash-item travel-dash-item--obstacle";
        element.dataset.collectible = collectible ? "1" : "0";
        element.dataset.lane = String(lane);
        element.dataset.z = "0";
        element.style.left = `${laneToX(lane)}%`;
        itemsLayer.appendChild(element);
        items.push({ element, lane, z: 0, collectible });
      };

      const cleanupItem = (item) => {
        item.element.remove();
      };

      const finishGame = () => {
        playing = false;
        window.clearInterval(dashTimer);
        dashTimer = null;
        window.cancelAnimationFrame(animationFrame);
        animationFrame = null;
        startButton.textContent = "Tekrar Baslat";
        hud.textContent = `Tur bitti. Skorun ${score}. Tekrar dene.`;

        while (items.length) {
          cleanupItem(items.pop());
        }

        const best = Number(window.localStorage.getItem(BEST_KEY) || 0);
        if (score > best) {
          window.localStorage.setItem(BEST_KEY, String(score));
          bestEl.textContent = String(score);
        }
      };

      const renderFrame = (timestamp) => {
        if (!playing) return;
        if (!lastSpawn) lastSpawn = timestamp;

        if (timestamp - lastSpawn > 650) {
          spawnItem();
          lastSpawn = timestamp;
        }

        for (let index = items.length - 1; index >= 0; index -= 1) {
          const item = items[index];
          item.z += speed;
          const scale = 0.35 + item.z * 1.15;
          const translateY = item.z * 365;
          item.element.style.transform = `translate(-50%, ${translateY}px) scale(${scale})`;
          item.element.style.opacity = String(Math.min(1, 0.25 + item.z * 1.35));

          if (item.z >= 0.92) {
            if (item.lane === laneIndex) {
              if (item.collectible) {
                score += 20;
                hud.textContent = "Bilet toplandi. Harika devam et.";
              } else {
                score = Math.max(0, score - 18);
                timeLeft = Math.max(0, timeLeft - 3);
                timerEl.textContent = String(timeLeft);
                hud.textContent = "Engele carptin. Dikkat et.";
              }
              scoreEl.textContent = String(score);
            }

            cleanupItem(item);
            items.splice(index, 1);
          }
        }

        animationFrame = window.requestAnimationFrame(renderFrame);
      };

      const startGame = () => {
        while (items.length) {
          cleanupItem(items.pop());
        }

        laneIndex = 1;
        setLane(1);
        score = 0;
        timeLeft = 45;
        speed = 0.013;
        lastSpawn = 0;
        playing = true;
        scoreEl.textContent = "0";
        timerEl.textContent = "45";
        hud.textContent = "Kostur! Biletleri topla, engellerden kac.";
        startButton.textContent = "Oynaniyor...";

        window.clearInterval(dashTimer);
        dashTimer = window.setInterval(() => {
          timeLeft -= 1;
          timerEl.textContent = String(timeLeft);
          speed += 0.00035;
          if (timeLeft <= 0) finishGame();
        }, 1000);

        window.cancelAnimationFrame(animationFrame);
        animationFrame = window.requestAnimationFrame(renderFrame);
      };

      startButton.addEventListener("click", () => {
        if (playing) return;
        startGame();
      });

      leftButton.addEventListener("click", () => setLane(laneIndex - 1));
      rightButton.addEventListener("click", () => setLane(laneIndex + 1));

      window.addEventListener("keydown", (event) => {
        if (!playing) return;
        if (event.key === "ArrowLeft") {
          setLane(laneIndex - 1);
        } else if (event.key === "ArrowRight") {
          setLane(laneIndex + 1);
        }
      });

      syncBest();
    };

    const initTurboRace = () => {
      const canvas = document.getElementById("race-canvas");
      const startButton = document.getElementById("start-race-game");
      const leftButton = document.getElementById("race-left");
      const rightButton = document.getElementById("race-right");
      const scoreEl = document.getElementById("race-score");
      const speedEl = document.getElementById("race-speed");
      const bestEl = document.getElementById("race-best");
      const noteEl = document.getElementById("race-note");
      if (!canvas || !startButton || !leftButton || !rightButton || !scoreEl || !speedEl || !bestEl || !noteEl) return;

      const ctx = canvas.getContext("2d");
      if (!ctx) return;

      const BEST_KEY = "oneticketaway-turbo-race-best";
      let playing = false;
      let frameId = null;
      let score = 0;
      let speed = 0;
      let lane = 1;
      let playerX = 0;
      let roadOffset = 0;
      let curve = 0;
      let curveTarget = 0;
      let lastTime = 0;
      let spawnCooldown = 0;
      const cars = [];

      const laneToOffset = (laneIndex) => [-0.52, 0, 0.52][laneIndex];
      const syncBest = () => {
        bestEl.textContent = String(Number(window.localStorage.getItem(BEST_KEY) || 0));
      };

      const resetGame = () => {
        playing = true;
        score = 0;
        speed = 0.65;
        lane = 1;
        playerX = 0;
        roadOffset = 0;
        curve = 0;
        curveTarget = 0;
        spawnCooldown = 0;
        cars.length = 0;
        scoreEl.textContent = "0";
        speedEl.textContent = "65";
        noteEl.textContent = "Hizlan, serit degistir ve trafik arasindan ak.";
        startButton.textContent = "Yarisiyor...";
      };

      const finishGame = () => {
        playing = false;
        window.cancelAnimationFrame(frameId);
        frameId = null;
        startButton.textContent = "Tekrar Baslat";
        noteEl.textContent = `Kaza yaptin. Skorun ${score}. Tekrar dene.`;
        const best = Number(window.localStorage.getItem(BEST_KEY) || 0);
        if (score > best) {
          window.localStorage.setItem(BEST_KEY, String(score));
          bestEl.textContent = String(score);
        }
      };

      const spawnCar = () => {
        cars.push({
          lane: Math.floor(Math.random() * 3),
          z: 1,
          color: ["#f05d5d", "#58a6ff", "#ffd166", "#7bd389"][Math.floor(Math.random() * 4)]
        });
      };

      const drawSky = (width, height) => {
        const gradient = ctx.createLinearGradient(0, 0, 0, height);
        gradient.addColorStop(0, "#74c8ff");
        gradient.addColorStop(0.58, "#dff4ff");
        gradient.addColorStop(1, "#f6ede4");
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, width, height);

        ctx.fillStyle = "rgba(255,255,255,0.7)";
        ctx.beginPath();
        ctx.arc(width * 0.18, height * 0.18, 38, 0, Math.PI * 2);
        ctx.arc(width * 0.24, height * 0.17, 30, 0, Math.PI * 2);
        ctx.arc(width * 0.21, height * 0.14, 26, 0, Math.PI * 2);
        ctx.fill();
      };

      const drawRoad = (width, height) => {
        for (let i = 0; i < 42; i += 1) {
          const perspective = i / 42;
          const nextPerspective = (i + 1) / 42;
          const y = height * (0.32 + perspective * 0.68);
          const nextY = height * (0.32 + nextPerspective * 0.68);
          const roadHalfWidth = width * (0.08 + perspective * 0.34);
          const nextRoadHalfWidth = width * (0.08 + nextPerspective * 0.34);
          const centerX = width * 0.5 + curve * 180 * perspective;
          const nextCenterX = width * 0.5 + curve * 180 * nextPerspective;

          ctx.fillStyle = i % 2 === 0 ? "#383d4a" : "#2b2f39";
          ctx.beginPath();
          ctx.moveTo(centerX - roadHalfWidth, y);
          ctx.lineTo(centerX + roadHalfWidth, y);
          ctx.lineTo(nextCenterX + nextRoadHalfWidth, nextY);
          ctx.lineTo(nextCenterX - nextRoadHalfWidth, nextY);
          ctx.closePath();
          ctx.fill();

          ctx.fillStyle = i % 2 === 0 ? "#68b66a" : "#4da457";
          ctx.beginPath();
          ctx.moveTo(0, y);
          ctx.lineTo(centerX - roadHalfWidth, y);
          ctx.lineTo(nextCenterX - nextRoadHalfWidth, nextY);
          ctx.lineTo(0, nextY);
          ctx.closePath();
          ctx.fill();

          ctx.beginPath();
          ctx.moveTo(centerX + roadHalfWidth, y);
          ctx.lineTo(width, y);
          ctx.lineTo(width, nextY);
          ctx.lineTo(nextCenterX + nextRoadHalfWidth, nextY);
          ctx.closePath();
          ctx.fill();

          if (i < 40) {
            ctx.strokeStyle = "rgba(255,255,255,0.55)";
            ctx.lineWidth = Math.max(2, perspective * 6);
            ctx.beginPath();
            ctx.moveTo(centerX, y);
            ctx.lineTo(nextCenterX, nextY);
            ctx.stroke();
          }
        }
      };

      const drawCar = (x, y, scale, color, player = false) => {
        const width = 48 * scale;
        const height = 88 * scale;
        ctx.save();
        ctx.translate(x, y);
        ctx.fillStyle = "rgba(0,0,0,0.18)";
        ctx.beginPath();
        ctx.ellipse(0, height * 0.48, width * 0.56, height * 0.18, 0, 0, Math.PI * 2);
        ctx.fill();

        ctx.fillStyle = color;
        ctx.fillRect(-width / 2, -height / 2, width, height);
        ctx.fillStyle = player ? "#f7fafc" : "#d9e2ec";
        ctx.fillRect(-width * 0.28, -height * 0.24, width * 0.56, height * 0.28);
        ctx.fillStyle = "#20242c";
        ctx.fillRect(-width * 0.46, -height * 0.42, width * 0.18, height * 0.24);
        ctx.fillRect(width * 0.28, -height * 0.42, width * 0.18, height * 0.24);
        ctx.fillRect(-width * 0.46, height * 0.18, width * 0.18, height * 0.24);
        ctx.fillRect(width * 0.28, height * 0.18, width * 0.18, height * 0.24);
        ctx.restore();
      };

      const updateCars = (delta, width, height) => {
        for (let i = cars.length - 1; i >= 0; i -= 1) {
          const car = cars[i];
          car.z -= delta * (0.42 + speed * 0.38);
          if (car.z <= 0) {
            cars.splice(i, 1);
            score += 18;
            scoreEl.textContent = String(score);
            continue;
          }

          const perspective = 1 - car.z;
          const centerX = width * 0.5 + curve * 180 * perspective;
          const roadHalfWidth = width * (0.08 + perspective * 0.34);
          const laneOffset = laneToOffset(car.lane) * roadHalfWidth * 0.72;
          const x = centerX + laneOffset;
          const y = height * (0.34 + perspective * 0.62);
          const scale = 0.35 + perspective * 1.05;

          drawCar(x, y, scale, car.color);

          if (car.z < 0.16 && car.lane === lane) {
            finishGame();
            return;
          }
        }
      };

      const render = (timestamp) => {
        if (!playing) return;
        if (!lastTime) lastTime = timestamp;
        const delta = Math.min(0.032, (timestamp - lastTime) / 1000);
        lastTime = timestamp;

        const width = canvas.width;
        const height = canvas.height;
        ctx.clearRect(0, 0, width, height);
        drawSky(width, height);

        roadOffset += speed * 18;
        curveTarget += (Math.random() - 0.5) * 0.02;
        curveTarget = Math.max(-1, Math.min(1, curveTarget));
        curve += (curveTarget - curve) * 0.018;
        drawRoad(width, height);

        spawnCooldown -= delta;
        if (spawnCooldown <= 0) {
          spawnCar();
          spawnCooldown = Math.max(0.48, 1.25 - speed * 0.5);
        }

        updateCars(delta, width, height);

        playerX += (laneToOffset(lane) - playerX) * 0.14;
        drawCar(width * 0.5 + playerX * width * 0.18, height * 0.86, 1.15, "#14a07c", true);

        speed = Math.min(1.8, speed + delta * 0.024);
        speedEl.textContent = String(Math.round(speed * 100));
        score += Math.floor(speed * 0.65);
        scoreEl.textContent = String(score);

        frameId = window.requestAnimationFrame(render);
      };

      const startGame = () => {
        resetGame();
        syncBest();
        lastTime = 0;
        window.cancelAnimationFrame(frameId);
        frameId = window.requestAnimationFrame(render);
      };

      const steer = (dir) => {
        if (!playing) return;
        lane = Math.max(0, Math.min(2, lane + dir));
      };

      startButton.addEventListener("click", () => {
        if (playing) return;
        startGame();
      });

      leftButton.addEventListener("click", () => steer(-1));
      rightButton.addEventListener("click", () => steer(1));

      window.addEventListener("keydown", (event) => {
        if (!playing) return;
        if (event.key === "ArrowLeft") steer(-1);
        if (event.key === "ArrowRight") steer(1);
        if (event.key === "ArrowUp") speed = Math.min(1.95, speed + 0.08);
      });

      syncBest();
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      drawSky(canvas.width, canvas.height);
      drawRoad(canvas.width, canvas.height);
      drawCar(canvas.width * 0.5, canvas.height * 0.86, 1.15, "#14a07c", true);
    };

    initSkyChase();
    initMemoryRoute();
    initPerfectLanding();
    initTravelDash();
    initTurboRace();
  })();
</script>
